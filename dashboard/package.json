{
  "name": "dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "bash scripts/kill-port.sh",
    "dev": "NEXT_DIST_DIR=.next-dev next dev",
    "build": "rm -f .data/cortextos-*-build-*.db* && CORTEXTOS_BUILD_DB_ISOLATION=$(node -p 'Date.now()') NEXT_DIST_DIR=.next-build next build",
    "start": "next start",
    "prestart:prod": "bash scripts/kill-port.sh && bash scripts/ensure-built.sh",
    "start:prod": "next start -p ${PORT:-3000}",
    "build:prod": "rm -f .data/cortextos-*-build-*.db* && CORTEXTOS_BUILD_DB_ISOLATION=$(node -p 'Date.now()') NEXT_DIST_DIR=.next-build next build",
    "postbuild": "bash scripts/stamp-build-commit.sh .next-build",
    "postbuild:prod": "bash scripts/stamp-build-commit.sh .next-build",
    "lint": "eslint",
    "test": "vitest run --root .. dashboard/src",
    "test:codex": "vitest run --root .. dashboard/src/lib/__tests__/cost-parser-codex.test.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@sentry/nextjs": "^10.54.0",
    "@tabler/icons-react": "^3.44.0",
    "@tailwindcss/typography": "^0.5.20",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "gray-matter": "^4.0.3",
    "isomorphic-dompurify": "^3.15.0",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.21.0",
    "marked": "^18.0.0",
    "next": "16.2.7",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "^3.8.0",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^10",
    "eslint-config-next": "16.2.9",
    "sharp": "^0.35.2",
    "tailwindcss": "^4",
    "typescript": "^6",
    "vitest": "^4.1.1"
  }
}
